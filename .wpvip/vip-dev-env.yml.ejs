configuration-version: 1
slug: safe-publish-mirror
title: Just another WordPress site
php: 8.2
wordpress: 7.0
app-code: demo
# Update to the local path of MU-plugins when working on the integration loader code.
mu-plugins: demo
multisite: false
phpmyadmin: false
elasticsearch: false
xdebug: true
mailpit: false
photon: false
cron: false
overrides: |
  services:
    php:
      services:
        environment:
          WP_TESTS_DIR: /wp/wp-content/wordpress-tests-lib
        volumes:
          - <%= configDir %>/..:/wp/wp-content/plugins/safe-publish-mirror
          - <%= configDir %>/plugin-loader.php:/wp/wp-content/client-mu-plugins/plugin-loader.php
          - <%= configDir %>/empty:/wp/wp-content/empty
  tooling:
    dev-shell:
      service: php
      cmd:
        - /bin/bash -i
      dir: /wp/wp-content/plugins/safe-publish-mirror
      user: www-data
      description: Run a development shell

    unit-tests:
      service: php
      cmd:
        - composer test:unit
      dir: /wp/wp-content/plugins/safe-publish-mirror
      user: www-data
      description: Run unit tests
